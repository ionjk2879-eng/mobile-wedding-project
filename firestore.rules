rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 청첩장 데이터
    match /invitations/{slug} {
      // 누구나 읽기 가능 (하객 열람)
      allow read: if true;

      // 생성: 로그인 필수, ownerUid가 본인이어야 함
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.slug is string
        && request.resource.data.slug == slug;

      // 수정: 본인 데이터만
      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.slug == slug;

      // 삭제: 본인 데이터만
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    // RSVP 응답 (서브컬렉션)
    match /invitations/{slug}/rsvp/{docId} {
      // 관리자: 읽기 가능
      allow read: if true;

      // 하객: 쓰기 가능 (유효성 검사)
      allow create: if true
        && request.resource.data.guestName is string
        && request.resource.data.guestName.size() > 0
        && request.resource.data.guestName.size() <= 50
        && request.resource.data.isAttending is bool
        && request.resource.data.totalGuests is int
        && request.resource.data.totalGuests >= 1
        && request.resource.data.totalGuests <= 10
        && (!('message' in request.resource.data) || request.resource.data.message.size() <= 500);

      // 같은 이름으로 재제출 시 덮어쓰기 허용
      allow update: if true
        && request.resource.data.guestName is string
        && request.resource.data.guestName.size() > 0
        && request.resource.data.guestName.size() <= 50
        && request.resource.data.isAttending is bool
        && request.resource.data.totalGuests is int
        && request.resource.data.totalGuests >= 1
        && request.resource.data.totalGuests <= 10
        && (!('message' in request.resource.data) || request.resource.data.message.size() <= 500);

      allow delete: if false;
    }

    // 방명록 (서브컬렉션)
    match /invitations/{slug}/guestbook/{docId} {
      allow read: if true;

      allow create: if true
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 500
        && request.resource.data.password is string
        && request.resource.data.password.size() == 4
        && request.resource.data.side is string
        && request.resource.data.side in ['groom', 'bride'];

      allow delete: if true;
    }

    // 그 외 모든 경로 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}