{
  "name": "sonett",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "dev:worker": "npm run build && wrangler dev --env dev",
    "migrate:dev": "wrangler d1 migrations apply sonett-db-dev --env dev --local",
    "migrate:dev:remote": "wrangler d1 migrations apply sonett-db-dev --env dev --remote",
    "test": "playwright test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.284.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.18.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@playwright/test": "^1.61.0",
    "@vitejs/plugin-react": "^4.0.3",
    "sharp": "^0.35.2",
    "typescript": "^5.0.2",
    "vite": "^4.4.5",
    "wrangler": "^4.107.0"
  }
}
